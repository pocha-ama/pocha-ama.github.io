---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a href="{{ page.cv_pdf | relative_url }}" target="_blank" rel="noopener noreferrer" class="float-right">
          <i class="fas fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="cv">
      {% for data in site.data.cv.sections %}
        <a name="{{ data[0] }}"></a>
        <div class="card mt-3 p-3">
          <h3 class="card-title font-weight-medium">{{ data[0] }}</h3>
          <div>
            {% if data[0] == 'Skills' or data[0] == 'Interests' %}
              <div class="list-groups">
                {% for entry in data[1] %}
                  <div class="list-group-item border-0 p-0 mb-2">
                    <h6 class="title font-weight-bold mb-1">{{ entry.label | default: entry.name }}</h6>
                    <span style="font-size: 0.95rem;">{{ entry.details | default: entry.keywords }}</span>
                  </div>
                {% endfor %}
              </div>
            {% else %}
              <table class="table table-sm table-borderless table-responsive">
                {% for entry in data[1] %}
                  <tr>
                    <td class="p-1 pr-2 font-weight-bold" style="min-width: 140px; font-size: 0.95rem;">
                      {% if entry.start_date and entry.end_date %}
                        {{ entry.start_date }} - {{ entry.end_date }}
                      {% elsif entry.date %}
                        {{ entry.date }}
                      {% endif %}
                    </td>
                    <td class="p-1 pl-2 font-weight-light text">
                      {% assign title_text = entry.position | default: entry.degree | default: entry.name %}
                      {% if entry.url %}
                        <h6 class="title font-weight-bold mb-1"><a href="{{ entry.url }}" target="_blank">{{ title_text }}</a></h6>
                      {% else %}
                        <h6 class="title font-weight-bold mb-1">{{ title_text }}</h6>
                      {% endif %}

                      {% assign sub_title = entry.company | default: entry.institution | default: entry.location %}
                      {% if sub_title %}
                        <h6 class="mb-1" style="font-size: 0.95rem;">{{ sub_title }}</h6>
                      {% endif %}

                      {% if entry.highlights %}
                        <ul class="items mt-2 mb-0" style="padding-left: 1.2rem;">
                          {% for hl in entry.highlights %}
                            <li><span class="item" style="font-size: 0.9rem;">{{ hl }}</span></li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </table>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </article>
</div>